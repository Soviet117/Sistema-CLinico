# ============================================
# VARIABLES DE ENTORNO - SISTEMA CLINICO
# ============================================
# Copia este archivo como .env y completa los valores

# Variables de PostgreSQL (usadas por docker-compose)
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=db_sistema_clinico

# Base de datos PostgreSQL (se genera desde las variables anteriores)
DATABASE_URL="postgresql://tu_usuario:tu_password@host:5432/db_sistema_clinico"

# Variables para Render (se configuran en el dashboard)
# DATABASE_URL se genera automáticamente desde el blueprint
# NODE_ENV=production
# NEXTAUTH_URL=https://tu-app.onrender.com
