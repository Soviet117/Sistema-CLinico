// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums para roles, géneros y estados
enum Role {
  ADMIN
  DOCTOR
  RECEPCIONISTA
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum EstadoCita {
  PROGRAMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
}

enum EstadoMedico {
  ACTIVO
  INACTIVO
}

enum EstadoBox {
  DISPONIBLE
  OCUPADO
  MANTENIMIENTO
}

// Modelo User para autenticación básica
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  rol          Role     @default(DOCTOR)
  nombre       String

  // Relaciones inversas (1:N)
  medico           Medico? // Un usuario puede ser Médico
  citasGestionadas Cita[]  // Citas creadas por este usuario (como recepcionista o médico)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Modelo Medico
model Medico {
  id             String       @id @default(uuid())
  especialidad   String
  numColegiatura String       @unique
  estado         EstadoMedico @default(ACTIVO)

  // Relación con User
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relaciones Inversas
  historias      HistoriaClinica[]
  citas          Cita[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Modelo Box (Consultorio)
model Box {
  id         String     @id @default(uuid())
  nombre     String     @unique
  capacidad  Int        @default(1)
  tipo       String     
  estado     EstadoBox  @default(DISPONIBLE)

  citas      Cita[]
  historias  HistoriaClinica[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// Modelo Paciente para datos personales
model Paciente {
  id               String   @id @default(uuid())
  nombre           String
  apellido         String
  fechaNacimiento  DateTime
  genero           Genero
  tipoSangre       String?
  contacto         String?
  alergias         String?
  antecedentes     String?
  estadoClinico    String?

  // Relaciones inversas (1:N)
  historiasClinicas HistoriaClinica[]
  citas            Cita[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Modelo HistoriaClinica para el registro de consultas
model HistoriaClinica {
  id              String   @id @default(uuid())
  fecha           DateTime @default(now())
  motivo          String
  sintomas        String
  diagnostico     String?
  planTratamiento String?

  // Signos vitales
  presion         String   // Ej: "120/80"
  pulso           Decimal  // Latidos por minuto
  temperatura     Decimal  // En grados Celsius
  peso            Decimal  // En kg

  // Relación con Paciente
  pacienteId      String
  paciente        Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  // Relación con Médico (Modelo Medico)
  medicoId        String
  medico          Medico   @relation(fields: [medicoId], references: [id], onDelete: Restrict)

  // Relación con Box
  boxId           String?
  box             Box?     @relation(fields: [boxId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Modelo Cita para gestión de agenda
model Cita {
  id              String     @id @default(uuid())
  fechaHoraInicio DateTime
  fechaHoraFin    DateTime
  motivo          String
  estado          EstadoCita @default(PROGRAMADA)

  // Relación con Paciente
  pacienteId      String
  paciente        Paciente   @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  // Quién agendó la cita
  usuarioId       String
  usuario         User       @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  // Médico asignado a la cita (Obligatorio)
  medicoId        String
  medico          Medico     @relation(fields: [medicoId], references: [id], onDelete: Restrict)

  // Box asignado a la cita (Obligatorio)
  boxId           String
  box             Box        @relation(fields: [boxId], references: [id], onDelete: Restrict)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}