// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums para roles, géneros y estados
enum Role {
  ADMIN
  DOCTOR
  RECEPCIONISTA
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum EstadoCita {
  PROGRAMADA
  EN_CURSO
  PENDIENTE_PAGO
  COMPLETADA
  CANCELADA
}

enum EstadoMedico {
  ACTIVO
  INACTIVO
}

enum EstadoBox {
  DISPONIBLE
  OCUPADO
  MANTENIMIENTO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  ANULADA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  YAPE
  PLIN
}

enum EstadoAdelanto {
  NO_REQUIERE
  PENDIENTE
  COMPROBANTE_ENVIADO
  VALIDADO
  RECHAZADO
}

// Modelo Especialidad (Catálogo de Precios y Áreas)
model Especialidad {
  id         String   @id @default(uuid())
  nombre     String   @unique
  precioBase Decimal  @db.Decimal(10, 2)

  // Relaciones
  medicos    Medico[]
  boxes      Box[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Modelo User para autenticación básica
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  rol          Role     @default(DOCTOR)
  nombre       String

  activo         Boolean  @default(true)

  // Relaciones inversas (1:N)
  medico           Medico? // Un usuario puede ser Médico
  citasGestionadas Cita[]  // Citas creadas por este usuario (como recepcionista o médico)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RolePermission {
  id        String  @id @default(uuid())
  rol       Role
  moduleKey String
  activo    Boolean @default(true)

  @@unique([rol, moduleKey])
}

// Modelo Medico
model Medico {
  id             String       @id @default(uuid())
  numColegiatura String       @unique
  estado         EstadoMedico @default(ACTIVO)

  // Relación con Especialidad
  especialidadId String
  especialidad   Especialidad @relation(fields: [especialidadId], references: [id], onDelete: Restrict)

  // Relación con User
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relaciones Inversas
  historias      HistoriaClinica[]
  citas          Cita[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Modelo Box (Consultorio)
model Box {
  id         String     @id @default(uuid())
  nombre     String     @unique
  capacidad  Int        @default(1)
  tipo       String     
  estado     EstadoBox  @default(DISPONIBLE)

  // Especialidad asignada al Box
  especialidadId String
  especialidad   Especialidad @relation(fields: [especialidadId], references: [id], onDelete: Restrict)

  citas      Cita[]
  historias  HistoriaClinica[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// Modelo Paciente para datos personales
model Paciente {
  id               String   @id @default(uuid())
  nombre           String
  apellido         String
  fechaNacimiento  DateTime
  genero           Genero
  tipoSangre       String?
  contacto         String?
  alergias         String?
  antecedentes     String?
  estadoClinico    String?

  // Relaciones inversas (1:N)
  historiasClinicas HistoriaClinica[]
  citas            Cita[]
  facturas         Factura[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Modelo HistoriaClinica para el registro de consultas
model HistoriaClinica {
  id              String   @id @default(uuid())
  fecha           DateTime @default(now())
  motivo          String
  sintomas        String
  diagnostico     String?
  planTratamiento String?

  // Signos vitales
  presion         String   // Ej: "120/80"
  pulso           Decimal  // Latidos por minuto
  temperatura     Decimal  // En grados Celsius
  peso            Decimal  // En kg

  // Relación con Paciente
  pacienteId      String
  paciente        Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  // Relación con Médico (Modelo Medico)
  medicoId        String
  medico          Medico   @relation(fields: [medicoId], references: [id], onDelete: Restrict)

  // Relación con Box
  boxId           String?
  box             Box?     @relation(fields: [boxId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Modelo Cita para gestión de agenda
model Cita {
  id              String     @id @default(uuid())
  fechaHoraInicio DateTime
  fechaHoraFin    DateTime
  motivo          String
  estado          EstadoCita @default(PROGRAMADA)

  // Relación con Paciente
  pacienteId      String
  paciente        Paciente   @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  // Quién agendó la cita
  usuarioId       String
  usuario         User       @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  // Médico asignado a la cita (Obligatorio)
  medicoId        String
  medico          Medico     @relation(fields: [medicoId], references: [id], onDelete: Restrict)

  // Box asignado a la cita (Obligatorio)
  boxId           String
  box             Box        @relation(fields: [boxId], references: [id], onDelete: Restrict)

  // Relación opcional con Factura (1 a 1 inversa)
  factura         Factura?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// Modelo Factura (Gestión Financiera)
model Factura {
  id            String      @id @default(uuid())
  montoBase     Decimal     @db.Decimal(10, 2) @default(0)
  montoAdelanto Decimal     @db.Decimal(10, 2) @default(0)
  montoTotal    Decimal     @db.Decimal(10, 2)
  estadoPago    EstadoPago  @default(PENDIENTE)
  metodoPago    MetodoPago?
  metodoAdelanto MetodoPago?
  estadoAdelanto EstadoAdelanto @default(NO_REQUIERE)
  comprobanteUrl String?
  observacionPago String?
  fechaComprobante DateTime?
  fechaValidacion DateTime?
  validadoPorId String?
  categoria     String      @default("Consulta")
  fechaEmision  DateTime    @default(now())

  // Relación con Cita (1:1 mandatoria desde Factura, cascada si Cita se borra)
  citaId        String      @unique
  cita          Cita        @relation(fields: [citaId], references: [id], onDelete: Cascade)

  // Relación con Paciente
  pacienteId    String
  paciente      Paciente    @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
